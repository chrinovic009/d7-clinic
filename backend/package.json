{
  "name": "d7-clinique-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "prisma:generate": "npx prisma --schema ../prisma/schema.prisma generate",
    "prisma:db:push": "npx prisma --schema ../prisma/schema.prisma db push",
    "prisma:studio": "npx prisma --schema ../prisma/schema.prisma studio",
    "db:seed": "npx prisma --schema ../prisma/schema.prisma db seed"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "dotenv": "^16.3.1",
    "@prisma/client": "^5.14.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.14.2",
    "@types/passport-jwt": "^3.0.8",
    "prisma": "^5.14.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.4"
  }
}
