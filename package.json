{
  "name": "d7-clinnique",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:frontend": "vite --config frontend/vite.config.ts --host",
    "dev:backend": "cd backend && npx ts-node-dev --transpile-only --project tsconfig.json --respawn src/main.ts",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "vite build frontend --config frontend/vite.config.ts",
    "build:backend": "cd backend && tsc -p tsconfig.build.json",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "cd backend && node dist/main.js",
    "lint": "eslint .",
    "prisma:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema backend/prisma/schema.prisma",
    "db:seed": "prisma db seed --schema backend/prisma/schema.prisma",
    "prisma:db:push": "prisma db push --schema backend/prisma/schema.prisma",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.15",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.15",
    "@fullcalendar/timegrid": "^6.1.20",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.3",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/platform-socket.io": "^11.1.26",
    "@nestjs/websockets": "^11.1.26",
    "@prisma/client": "^5.22.0",
    "apexcharts": "^4.1.0",
    "bcrypt": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.3.1",
    "flatpickr": "^4.6.13",
    "lucide-react": "^1.17.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "react": "^19.0.0",
    "react-apexcharts": "^1.7.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-router": "^7.1.5",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "swiper": "^12.1.4",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.17",
    "@types/node": "^25.9.1",
    "@types/passport-jwt": "^3.0.8",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "postcss": "^8.5.15",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^6.1.0",
    "vite-plugin-svgr": "^4.3.0"
  }
}
